# Caddyfile для статического сайта navigator-prof.ru
# Задача: на несуществующие страницы отдавать честный HTTP 404,
# а НЕ подменять их главной страницей (index.html).

:80 {
	root * .
	encode gzip
	file_server

	# Любая ошибка (в т.ч. 404) -> показываем 404.html,
	# СОХРАНЯЯ исходный код ответа (404), как просит Яндекс.
	handle_errors {
		rewrite * /404.html
		file_server
	}
}
